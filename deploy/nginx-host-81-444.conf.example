# =============================================================================
# Nginx host — test1.nexquoteapp.com: HTTPS cổng 444 (mặc định cho domain này)
# =============================================================================
# Sao chép: sudo cp nginx-host-81-444.conf.example /etc/nginx/sites-available/test1.nexquoteapp.com
# Bật site:  sudo ln -sf /etc/nginx/sites-available/test1.nexquoteapp.com /etc/nginx/sites-enabled/
# Kiểm tra: sudo nginx -t && sudo systemctl reload nginx
#
# Docker (trong .env): phải bind localhost để Nginx host chiếm 444/81:
#   DOCKER_FE_PUBLISH=127.0.0.1:8080
#   DOCKER_BE_PUBLISH=127.0.0.1:8082
#
# Firewall: mở TCP 81 và 444 (và 80 nếu Certbot cần).
# Trình duyệt: https://test1.nexquoteapp.com:444  (cổng 444 bắt buộc ghi rõ trừ khi bạn thêm 443).
#
# Chứng chỉ Let’s Encrypt (ví dụ — chỉnh đường dẫn theo certbot trên máy bạn):
#   sudo certbot certonly --webroot -w /var/www/html -d test1.nexquoteapp.com
#   hoặc certbot nginx (nếu đã có server listen tạm phù hợp)
# =============================================================================

# HTTP :81 — chuyển sang HTTPS :444 (URL chuẩn của site)
server {
    listen 81;
    listen [::]:81;
    server_name test1.nexquoteapp.com;

    location / {
        return 301 https://$host:444$request_uri;
    }
}

# HTTPS :444 — site chính (default_server = bắt request không khớp server_name khác trên cổng 444)
server {
    listen 444 ssl http2 default_server;
    listen [::]:444 ssl http2 default_server;
    server_name test1.nexquoteapp.com;

    ssl_certificate /etc/letsencrypt/live/test1.nexquoteapp.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/test1.nexquoteapp.com/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    # Giao diện (container fe → Nginx :80 nội bộ)
    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port 444;
    }

    location /api {
        proxy_pass http://127.0.0.1:8082;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port 444;
    }

    location /ws {
        proxy_pass http://127.0.0.1:8082;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
