# =============================================================================
# Nginx — HTTP cổng 80: URL không ghi cổng, KHÔNG dùng 443 (không HTTPS)
# =============================================================================
# Truy cập: http://test1.nexquoteapp.com  (không có :80 trên thanh địa chỉ)
#
# Phù hợp khi: không dùng TLS, hoặc 443 đã bận và bạn chấp nhận chỉ HTTP công khai.
# Không dùng được https://... mà không có cổng nếu không listen 443 (quy ước trình duyệt).
#
# Điều kiện: cổng 80 trên VPS còn trống (hoặc gộp server_name trong cùng Nginx).
#
# Docker (.env):
#   DOCKER_FE_PUBLISH=127.0.0.1:8080
#   DOCKER_BE_PUBLISH=127.0.0.1:8082
#
# .env (http, không cổng):
#   APP_FRONTEND_BASE_URL=http://test1.nexquoteapp.com
#   APP_CORS_ALLOWED_ORIGINS=http://test1.nexquoteapp.com
#   VITE_API_BASE_URL=http://test1.nexquoteapp.com
#
# Firewall: sudo ufw allow 80/tcp
# =============================================================================

server {
    listen 80;
    listen [::]:80;
    server_name test1.nexquoteapp.com;

    location / {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port 80;
    }

    location /api {
        proxy_pass http://127.0.0.1:8082;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        proxy_set_header X-Forwarded-Port 80;
    }

    location /ws {
        proxy_pass http://127.0.0.1:8082;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
