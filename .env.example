# Production — copy thành .env và điền giá trị thực (cùng cấp docker-compose.prod.yml)

# =============================================================================
# test1.nexquoteapp.com:444 — HTTPS cổng 444 với Nginx host reverse-proxy
# =============================================================================
# 1. Copy file này thành .env: cp .env.example .env
# 2. Điền các giá trị thực vào phần bên dưới
# 3. Chạy: docker compose -f docker-compose.prod.yml up -d
# =============================================================================

# --- Docker publish (QUAN TRỌNG — phải set cho Nginx host) ---
# Bind Docker ports vào 127.0.0.1 để Nginx host chiếm cổng, tránh trùng lặp
DOCKER_FE_PUBLISH=127.0.0.1:8080
DOCKER_BE_PUBLISH=127.0.0.1:8082

# --- Nginx Host Reverse Proxy (444) ---
# test1.nexquoteapp.com:444 config: deploy/nginx-host-81-444.conf.example
# Trình duyệt truy cập: https://test1.nexquoteapp.com:444
APP_FRONTEND_BASE_URL=https://test1.nexquoteapp.com:444
APP_CORS_ALLOWED_ORIGINS=https://test1.nexquoteapp.com:444
VITE_API_BASE_URL=https://test1.nexquoteapp.com:444

SPRING_DATASOURCE_PASSWORD=your_db_password
SECURITY_JWT_SECRET=your_base64_jwt_secret

SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-app-password
APP_MAIL_FROM=your-email@gmail.com

# --- AI sidecar (OCR + proctoring + chat) ---
APP_AI_SERVICE_ENABLED=true
APP_AI_SERVICE_BASE_URL=http://ai-service:8090
# OpenAI-compatible proxy base URL (thay api.openai.com bằng gateway)
# Ví dụ key4u.shop: https://api.key4u.shop/v1
OPENAI_API_BASE_URL=https://api.key4u.shop/v1

# Key mặc định — dùng cho tất cả model không có key riêng trong map
OPENAI_API_KEY=your_default_api_key
APP_AI_API_KEY=your_default_api_key
APP_AI_MODEL=gpt-4o-mini

# --- Multi-key theo model (chat bot) ---
# Cách 1: file JSON (khuyến nghị — không commit key)
#   Tạo thư mục secrets/ và file secrets/model-keys.json
#   Ví dụ nội dung: {"gpt-4o-mini":"sk-...","claude-sonnet-4-6-thinking":"sk-...","gemini-2.5-pro":"sk-..."}
#   Set quyền: chmod 600 secrets/model-keys.json
#   Không commit secrets/ vào git!
APP_AI_MODEL_KEYS_FILE=./secrets/model-keys.json

# Cách 2: inline JSON (dev — KHÔNG dùng trên production)
# APP_AI_MODEL_KEYS_JSON={"gpt-4o-mini":"sk-...","claude-sonnet-4-6-thinking":"sk-..."}

# Danh sách model cho phép chat (tùy chọn, nếu rỗng sẽ load từ ai-service)
# APP_AI_CHAT_ALLOWED_MODELS=gpt-4o-mini,claude-sonnet-4-6-thinking,gemini-2.5-pro
