# Local backend config.
# Copy this file to BE/.env when running `mvnw spring-boot:run` outside Docker.
# For VPS/Docker deployment, use the root .env next to docker-compose.prod.yml.

SPRING_DATASOURCE_URL=jdbc:postgresql://127.0.0.1:5432/datn
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=123
SPRING_JPA_DDL_AUTO=update

SECURITY_JWT_SECRET=CHANGE_ME_to_a_long_random_secret
DEMO_ADMIN_PASSWORD=CHANGE_ME_admin_password

APP_FRONTEND_BASE_URL=http://localhost:5173
APP_URL=http://localhost:8082
# APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

SPRING_MAIL_USERNAME=your-email@gmail.com
SPRING_MAIL_PASSWORD=your-app-password
APP_MAIL_FROM=your-email@gmail.com

APP_AI_SERVICE_ENABLED=true
APP_AI_SERVICE_BASE_URL=http://localhost:8090
# APP_AI_SERVICE_API_KEY=local-dev-key

EXAM_IMPORT_PYTHON_LEGACY_URL=http://localhost:8000
EXAM_IMPORT_PYTHON_DEFAULT=legacy
